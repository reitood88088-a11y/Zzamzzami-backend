generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Subject {
  English
  Chinese
  Japanese
}

enum WordStatus {
  KNOW
  AGAIN
  DONT_KNOW
}

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  name                String
  totalStudyMinutes   Int                @default(0) @map("total_study_minutes")
  consecutiveDays     Int                @default(0) @map("consecutive_days")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  diaries             Diary[]
  wordStatuses        UserWordStatus[]
  quizAttempts        QuizAttempt[]
  quotes              UserQuote[]
  dailyStudyTimes     DailyStudyTime[]

  @@map("user")
}

model Diary {
  id                  String             @id @default(uuid())
  userId              String             @map("user_id")
  subject             Subject
  date                DateTime           @db.Date
  contentSnippet      String?            @map("content_snippet")
  fullText            String             @db.Text @map("full_text")
  isNew               Boolean            @default(true) @map("is_new")
  createdAt           DateTime           @default(now()) @map("created_at")

  user                User               @relation(fields: [userId], references: [id])
  words               Word[]
  quizzes             Quiz[]

  @@map("diary")
}

model Word {
  id                  String             @id @default(uuid())
  diaryId             String             @map("diary_id")
  word                String
  meaning             String
  exampleSentence     String?            @db.Text @map("example_sentence")
  createdAt           DateTime           @default(now()) @map("created_at")

  diary               Diary              @relation(fields: [diaryId], references: [id], onDelete: Cascade)
  userStatuses        UserWordStatus[]

  @@map("word")
}

model UserWordStatus {
  id                  String             @id @default(uuid())
  userId              String             @map("user_id")
  wordId              String             @map("word_id")
  status              WordStatus
  updatedAt           DateTime           @updatedAt @map("updated_at")

  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  word                Word               @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@map("user_word_status")
}

model Quiz {
  id                  String             @id @default(uuid())
  diaryId             String             @map("diary_id")
  question            String             @db.Text
  options             Json
  correctOptionIndex  Int                @map("correct_option_index")
  explanation         String             @db.Text
  createdAt           DateTime           @default(now()) @map("created_at")

  diary               Diary              @relation(fields: [diaryId], references: [id], onDelete: Cascade)
  attempts            QuizAttempt[]

  @@map("quiz")
}

model QuizAttempt {
  id                  String             @id @default(uuid())
  userId              String             @map("user_id")
  quizId              String             @map("quiz_id")
  isCorrect           Boolean            @map("is_correct")
  createdAt           DateTime           @default(now()) @map("created_at")

  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz                Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_attempt")
}

model UserQuote {
  id                  String             @id @default(uuid())
  userId              String             @map("user_id")
  text                String             @db.Text
  createdAt           DateTime           @default(now()) @map("created_at")

  user                User               @relation(fields: [userId], references: [id])

  @@map("user_quote")
}

model DailyStudyTime {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  subject         Subject
  date            DateTime @db.Date
  durationSeconds Int      @default(0) @map("duration_seconds")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subject, date])
  @@map("daily_study_time")
}
